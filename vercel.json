{
  "version": 2,
  "buildCommand": "cd client && npm install && npm run build",
  "outputDirectory": "client/dist",
  "functions": {
    "api/*.js": {
      "includeFiles": "server/data/**"
    }
  },
  "rewrites": [
    { "source": "/api/actual", "destination": "/api/actual" },
    { "source": "/api/forecast", "destination": "/api/forecast" },
    { "source": "/api/date-range", "destination": "/api/date-range" }
  ]
}
